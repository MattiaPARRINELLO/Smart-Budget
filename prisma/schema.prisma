// Prisma Schema - Smart Budget CMS
// Base de données SQLite pour simplicité de déploiement

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== UTILISATEURS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          String    @default("admin") // admin, editor
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  articles      Article[]
  sessions      Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== CONTENU ====================

model Article {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String    // Meta description
  content         String    // Markdown content
  coverImage      String?
  coverImageAlt   String?
  
  // SEO
  metaTitle       String?   // Si différent du titre
  metaDescription String?   // Si différent de excerpt
  focusKeyword    String?   // Mot-clé principal SEO
  seoScore        Int       @default(0) // Score SEO calculé 0-100
  
  // Organisation
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  tags            Tag[]
  
  // Auteur
  authorId        String
  author          User      @relation(fields: [authorId], references: [id])
  
  // Publication
  status          String    @default("draft") // draft, published, scheduled
  publishedAt     DateTime?
  scheduledAt     DateTime?
  
  // Stats
  views           Int       @default(0)
  readingTime     Int       @default(0) // en minutes
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  internalLinks   InternalLink[] @relation("sourceArticle")
  linkedFrom      InternalLink[] @relation("targetArticle")
  
  @@index([categoryId])
  @@index([authorId])
  @@index([status])
  @@index([publishedAt])
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  color       String    @default("#0ea5e9") // Couleur hex pour UI
  icon        String?   // Nom icône Lucide
  order       Int       @default(0)
  
  articles    Article[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Tag {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  
  articles    Article[]
  
  createdAt   DateTime  @default(now())
}

// Maillage interne intelligent
model InternalLink {
  id              String   @id @default(cuid())
  sourceArticleId String
  targetArticleId String
  anchorText      String
  
  sourceArticle   Article  @relation("sourceArticle", fields: [sourceArticleId], references: [id], onDelete: Cascade)
  targetArticle   Article  @relation("targetArticle", fields: [targetArticleId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  
  @@unique([sourceArticleId, targetArticleId])
}

// ==================== NEWSLETTER ====================

model Subscriber {
  id            String    @id @default(cuid())
  email         String    @unique
  firstName     String?
  
  // Double opt-in
  status        String    @default("pending") // pending, confirmed, unsubscribed
  confirmToken  String?   @unique
  confirmedAt   DateTime?
  
  // Tracking
  source        String?   // page où inscription
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([status])
}

model Newsletter {
  id          String    @id @default(cuid())
  subject     String
  content     String    // HTML ou Markdown
  
  status      String    @default("draft") // draft, scheduled, sent
  sentAt      DateTime?
  scheduledAt DateTime?
  
  // Stats
  recipientCount Int     @default(0)
  openCount      Int     @default(0)
  clickCount     Int     @default(0)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== MÉDIAS ====================

model Media {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  url         String
  alt         String?
  
  createdAt   DateTime @default(now())
}

// ==================== SETTINGS ====================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  
  updatedAt DateTime @updatedAt
}
