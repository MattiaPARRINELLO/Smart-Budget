# Smart Budget News

# Environment
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# Admin credentials (change in production!)
ADMIN_EMAIL=admin@smartbudget.fr
ADMIN_PASSWORD=SmartBudget2024!

# Email (Nodemailer - SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Smart Budget <noreply@smartbudget.fr>

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Smart Budget
NEXT_PUBLIC_SITE_DESCRIPTION=Conseils budget et finances pour étudiants et jeunes actifs

# Google AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
